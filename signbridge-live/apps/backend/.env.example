# Application
APP_NAME=SignBridge Live
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (ephemeral state only — not for permanent storage)
REDIS_URL=redis://localhost:8001/0
REDIS_ENABLED=true

# Supabase (PostgreSQL — users, meetings, transcripts, analytics, settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key
SUPABASE_ENABLED=truesignbridge-live/apps/backend/.env.example

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Gesture Recognition
GESTURE_ENABLED=true
GESTURE_MODEL_PATH=models/gesture_model.pkl
GESTURE_CONFIDENCE_THRESHOLD=0.6
GEMINI_GESTURE_ENABLED=false

# Security (JWT-ready)
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
